    {"type":"text","id":"leg1","x":600,"y":680,"width":640,"height":18,"angle":0,"strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":93,"version":1,"versionNonce":93,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"Cluster: same element adjacent = fires as ONE tick (faster). Merge 3 alike → tier-up (Fire→Fire II) + frees cells.","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Cluster: same element adjacent = fires as ONE tick (faster). Merge 3 alike → tier-up (Fire→Fire II) + frees cells.","lineHeight":1.4},
