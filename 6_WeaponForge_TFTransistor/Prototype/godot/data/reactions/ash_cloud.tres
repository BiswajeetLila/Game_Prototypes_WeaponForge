[gd_resource type="Resource" script_class="ReactionData" format=3]

[ext_resource type="Script" path="res://scripts/core/reaction_data.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"Ash Cloud"
trigger_tag = &"EARTH"
trigger_status = &"Burning"
