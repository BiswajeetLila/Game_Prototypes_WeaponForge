    {"type":"text","id":"leg3","x":600,"y":724,"width":640,"height":18,"angle":0,"strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":95,"version":1,"versionNonce":95,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"text":"Splitter: ×2 raw damage to its tiles (no combo). Mana bar grows 1 segment per group → fewer groups = faster attack.","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Splitter: ×2 raw damage to its tiles (no combo). Mana bar grows 1 segment per group → fewer groups = faster attack.","lineHeight":1.4},
