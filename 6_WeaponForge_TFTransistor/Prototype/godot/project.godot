; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="WeaponForge TFTransistor Prototype"
config/description="WeaponForge TFTransistor (Godot 4.6 Mono). Spatial-grid auto-battler with Transistor-style Function Matrix (Active/Modifier/Passive) and Magicka-style cross-hero status reactions. Seeded from 2_Weaponcraft_Godot/ P0 @ fbe426d on 2026-06-12. SSOT: docs/superpowers/specs/2026-06-12-fork-a-pivot-addendum.md (pending full Function catalog + status matrix spec)."
run/main_scene="res://scenes/Home.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

AccountState="*res://scripts/core/account_state.gd"
LaneState="*res://scripts/core/lane_state.gd"
ElementMediator="*res://scripts/core/element_mediator.gd"
UltController="*res://scripts/core/ult_controller.gd"
WaveDirector="*res://scripts/core/wave_director.gd"
CombatV2="*res://scripts/core/combat_v2.gd"
ShopV2="*res://scripts/core/shop_v2.gd"
DebugOverlay="*res://scripts/dev/debug_overlay.gd"
GameState="*res://scripts/core/game_state.gd"
ScreenshotHelper="*res://scripts/core/screenshot_helper.gd"
RNG="*res://scripts/core/rng.gd"
Recipes="*res://scripts/core/recipes.gd"
Merge="*res://scripts/core/merge.gd"
Shop="*res://scripts/core/shop.gd"
Combat="*res://scripts/core/combat.gd"
ScreenShake="*res://scripts/core/screen_shake.gd"
HitPause="*res://scripts/core/hit_pause.gd"
Heartbeat="*res://scripts/core/heartbeat.gd"
SignalTrace="*res://scripts/core/signal_trace.gd"

[debug]

file_logging/enable_file_logging=true

[display]

window/size/viewport_width=420
window/size/viewport_height=800
window/size/window_width_override=420
window/size/window_height_override=800
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="WeaponForge TFTransistor Prototype"

[input]

debug_screenshot={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194343,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
