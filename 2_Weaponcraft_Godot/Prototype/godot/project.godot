; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="WeaponCraft Godot Ultra-MVP"
config/description="WeaponCraft prototype (Godot 4.6 Mono). Crafting-Juice core hook: 3-slot Head/Hilt/Rune anvil + TFT gold shop/reroll, merge L1-L5, 8 named recipes (Steamburst/Inferno/...), Codex + First-Discovery overlay. 3 heroes (Bran start, Elara W3, Vex W6), 15 waves, bosses W5/W10/W15, Reforge-&-Retry on wipe. SSOT: docs/01_GDD.md."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/core/game_state.gd"
ScreenshotHelper="*res://scripts/core/screenshot_helper.gd"
RNG="*res://scripts/core/rng.gd"
Recipes="*res://scripts/core/recipes.gd"
Merge="*res://scripts/core/merge.gd"
Shop="*res://scripts/core/shop.gd"
Combat="*res://scripts/core/combat.gd"
ScreenShake="*res://scripts/core/screen_shake.gd"
HitPause="*res://scripts/core/hit_pause.gd"
Heartbeat="*res://scripts/core/heartbeat.gd"
SignalTrace="*res://scripts/core/signal_trace.gd"

[debug]

file_logging/enable_file_logging=true

[display]

window/size/viewport_width=420
window/size/viewport_height=800
window/size/window_width_override=420
window/size/window_height_override=800
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="WeaponCraft Godot Ultra-MVP"

[input]

debug_screenshot={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194343,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
